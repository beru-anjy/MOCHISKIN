{% extends 'base.html.twig' %}

{% block title %}Newsletter{% endblock %}
{% block description %}Abonnez-vous à la newsletter MOCHISKIN — conseils skincare chaque dimanche.{% endblock %}
{% block keywords %}newsletter, skincare, abonnement, conseils beauté{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .hero-newsletter {
        background: linear-gradient(135deg, var(--peach-main), var(--pink-main));
        color: white;
        padding: 5rem 0;
        text-align: center;
    }
    .hero-newsletter h1 { color: white; font-size: 2.8rem; }

    .benefit-card {
        display: flex;
        gap: 1.2rem;
        align-items: flex-start;
        background: var(--rose-light);
        border-radius: 14px;
        padding: 1.4rem;
        margin-bottom: 1.2rem;
        transition: transform .25s;
    }
    .benefit-card:hover { transform: translateX(8px); }
    .benefit-icon { font-size: 2rem; flex-shrink: 0; }

    .form-section {
        background: white;
        border-radius: 20px;
        padding: 2.5rem;
        box-shadow: 0 8px 28px rgba(255, 182, 193, .15);
    }

    .field-error {
        color: #dc3545;
        font-size: 0.82rem;
        margin-top: 4px;
        display: none;
    }

    .form-control.is-invalid {
        border-color: #dc3545;
    }

    .check-item {
        display: flex;
        align-items: center;
        gap: .8rem;
        background: var(--rose-light);
        border-radius: 10px;
        padding: .7rem 1rem;
        margin-bottom: .5rem;
        cursor: pointer;
    }
    .check-item:hover { background: var(--peach-light); }
    .check-item input { width: 18px; height: 18px; cursor: pointer; }

    .btn-subscribe {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, var(--peach-main), var(--pink-main));
        border: none;
        border-radius: 50px;
        color: white;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform .3s;
    }
    .btn-subscribe:hover { transform: translateY(-3px); }

    .testimonial-card {
        background: linear-gradient(135deg, var(--peach-light), var(--pink-light));
        border-radius: 14px;
        padding: 1.8rem;
        text-align: center;
    }

    .stats-band {
        background: linear-gradient(135deg, var(--peach-dark), var(--pink-main));
        color: white;
        border-radius: 18px;
        padding: 3rem;
        text-align: center;
        margin: 3rem 0;
    }

    .faq-q {
        font-weight: 600;
        color: var(--peach-dark);
        cursor: pointer;
        padding: 1rem 0;
        border-bottom: 1px solid var(--peach-light);
        display: flex;
        justify-content: space-between;
    }
    .faq-a {
        display: none;
        padding: .8rem 0 1rem;
        color: var(--gray-soft);
        line-height: 1.7;
    }
</style>
{% endblock %}

{% block body %}

    {# Hero #}
    <div class="hero-newsletter">
        <div class="container">
            <h1>Rejoignez la communauté skincare</h1>
            <p class="lead">Ne manquez plus aucun conseil beauté !</p>
        </div>
    </div>

    <div class="container my-5">
        <div class="row g-5">

            {# ── AVANTAGES (col gauche) ── #}
            <div class="col-md-5">
                <h2 class="mb-4" style="color: var(--peach-dark);">Pourquoi s'abonner ?</h2>

                <div class="benefit-card">
                    <span class="benefit-icon">📧</span>
                    <div>
                        <h6>1 email par semaine</h6>
                        <p class="mb-0 small">Chaque dimanche à 9h — condensé de mes meilleurs conseils.</p>
                    </div>
                </div>
                <div class="benefit-card">
                    <span class="benefit-icon">📚</span>
                    <div>
                        <h6>Contenus exclusifs</h6>
                        <p class="mb-0 small">Guides PDF, recettes maison DIY, conseils réservés aux abonnés.</p>
                    </div>
                </div>
                <div class="benefit-card">
                    <span class="benefit-icon">💰</span>
                    <div>
                        <h6>Codes promo partenaires</h6>
                        <p class="mb-0 small">15 à 30% de réduction sur vos marques préférées.</p>
                    </div>
                </div>
                <div class="benefit-card">
                    <span class="benefit-icon">🔔</span>
                    <div>
                        <h6>Alertes nouveautés</h6>
                        <p class="mb-0 small">Soyez la première informée des dernières tendances skincare.</p>
                    </div>
                </div>
                <div class="benefit-card">
                    <span class="benefit-icon">🎯</span>
                    <div>
                        <h6>Conseils sur mesure</h6>
                        <p class="mb-0 small">Recommandations adaptées à votre type de peau.</p>
                    </div>
                </div>
            </div>

            {# ── FORMULAIRE (col droite) ── #}
            <div class="col-md-7">
                <div class="form-section">
                    <h3 class="mb-4" style="color: var(--peach-dark);">✍️ Formulaire d'inscription</h3>

                    {# Messages flash (succès, info, erreur, warning) #}
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div style="
                                border-radius: 12px;
                                padding: 1rem 1.5rem;
                                margin-bottom: 1rem;
                                background: {% if label == 'success' %}#d1fae5{% elseif label == 'error' %}#fee2e2{% elseif label == 'warning' %}#fef3c7{% else %}#dbeafe{% endif %};
                                color: {% if label == 'success' %}#065f46{% elseif label == 'error' %}#991b1b{% elseif label == 'warning' %}#92400e{% else %}#1e40af{% endif %};">
                                {{ message }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {# Formulaire → pointe vers app_newsletter_subscribe (POST) #}
                    <form id="newsletterForm"
                          method="post"
                          novalidate
                          action="{{ path('app_newsletter_subscribe') }}">

                        {# Token CSRF pour sécuriser la soumission #}
                        <input type="hidden" name="_token"
                               value="{{ csrf_token('newsletter') }}">

                        <div class="mb-3">
                            <label for="firstName" class="form-label fw-semibold">
                                Votre prénom <span style="color: var(--peach-dark);">*</span>
                            </label>
                            <input type="text" class="form-control"
                                   id="firstName" name="firstName"
                                   placeholder="Marie">
                            <span class="field-error" id="err-firstName">Le prénom est obligatoire.</span>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">
                                Email <span style="color: var(--peach-dark);">*</span>
                            </label>
                            <input type="email" class="form-control"
                                   id="email" name="email"
                                   placeholder="marie@exemple.com">
                            <span class="field-error" id="err-email">Email invalide ou obligatoire.</span>
                        </div>

                        <div class="mb-3">
                            <label for="skinTypeId" class="form-label fw-semibold">Type de peau</label>
                            <select class="form-select" id="skinTypeId" name="skinTypeId">
                                <option value="">Sélectionnez...</option>
                                {% for skinType in skinTypes %}
                                    <option value="{{ skinType.id }}">{{ skinType.name }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Préoccupations</label>
                            <div class="check-item">
                                <input type="checkbox" id="c1" name="concerns[]" value="acne">
                                <label for="c1">Acné et imperfections</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="c2" name="concerns[]" value="antiage">
                                <label for="c2">Rides et anti-âge</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="c3" name="concerns[]" value="hydratation">
                                <label for="c3">Hydratation</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="c4" name="concerns[]" value="taches">
                                <label for="c4">Taches pigmentaires</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="c5" name="concerns[]" value="pores">
                                <label for="c5">Pores dilatés</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="c6" name="concerns[]" value="rougeurs">
                                <label for="c6">Rougeurs / Sensibilité</label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Centres d'intérêt</label>
                            <div class="check-item">
                                <input type="checkbox" id="i1" name="interests[]" value="skincare">
                                <label for="i1">Routine skincare</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="i2" name="interests[]" value="diy">
                                <label for="i2">DIY & recettes maison</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="i3" name="interests[]" value="ingredients">
                                <label for="i3">Décryptage ingrédients</label>
                            </div>
                            <div class="check-item">
                                <input type="checkbox" id="i4" name="interests[]" value="promos">
                                <label for="i4">Codes promo & bons plans</label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="check-item">
                                <input type="checkbox" id="consent" name="consent">
                                <label for="consent">
                                    J'accepte la politique de confidentialité
                                    <span style="color: var(--peach-dark);">*</span>
                                </label>
                            </div>
                            <span class="field-error" id="err-consent">Vous devez accepter la politique de confidentialité.</span>
                        </div>

                        <button type="submit" class="btn-subscribe">
                            S'inscrire à la newsletter
                        </button>

                    </form>
                </div>
            </div>

        </div>

        {# ── TÉMOIGNAGES ── #}
        <h2 class="text-center mt-5 mb-4" style="color: var(--peach-dark);">Ils nous font confiance</h2>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="testimonial-card">
                    <p class="fst-italic">"J'ai enfin trouvé la routine qui convient à ma peau sensible!"</p>
                    <strong style="color: var(--peach-dark);">Sophie, 28 ans</strong>
                </div>
            </div>
            <div class="col-md-3">
                <div class="testimonial-card">
                    <p class="fst-italic">"Des conseils concrets chaque semaine. J'adore!"</p>
                    <strong style="color: var(--peach-dark);">Marie, 35 ans</strong>
                </div>
            </div>
            <div class="col-md-3">
                <div class="testimonial-card">
                    <p class="fst-italic">"Je ne manque plus aucune nouveauté grâce aux alertes!"</p>
                    <strong style="color: var(--peach-dark);">Julie, 31 ans</strong>
                </div>
            </div>
            <div class="col-md-3">
                <div class="testimonial-card">
                    <p class="fst-italic">"Les guides PDF sont vraiment pratiques."</p>
                    <strong style="color: var(--peach-dark);">Laura, 26 ans</strong>
                </div>
            </div>
        </div>

        {# ── STATS ── #}
        <div class="stats-band">
            <div class="row">
                <div class="col-4">
                    <h3 class="text-white">5K</h3><p>Instagram</p>
                </div>
                <div class="col-4">
                    <h3 class="text-white">2.5K</h3><p>Abonnés Email</p>
                </div>
                <div class="col-4">
                    <h3 class="text-white">1K</h3><p>YouTube</p>
                </div>
            </div>
        </div>

        {# ── FAQ ── #}
        <div class="mb-5">
            <h2 class="mb-4" style="color: var(--peach-dark);">Questions fréquentes</h2>

            <div class="faq-q">
                <span>À quelle fréquence recevrai-je des emails ?</span><span>▼</span>
            </div>
            <div class="faq-a">1 email chaque dimanche à 9h. Pas de spam !</div>

            <div class="faq-q">
                <span>Puis-je me désinscrire facilement ?</span><span>▼</span>
            </div>
            <div class="faq-a">Oui ! Lien de désinscription en bas de chaque email.</div>

            <div class="faq-q">
                <span>Mes données sont-elles sécurisées ?</span><span>▼</span>
            </div>
            <div class="faq-a">Vos données sont 100% sécurisées — RGPD respecté.</div>

            <div class="faq-q">
                <span>Le contenu est-il vraiment gratuit ?</span><span>▼</span>
            </div>
            <div class="faq-a">Oui ! Newsletter et guides 100% gratuits, jamais de frais cachés.</div>
        </div>

    </div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function () {

    // ── FAQ accordion ─────────────────────────────────────────────────────────
    $('.faq-q').on('click', function () {
        $(this).next('.faq-a').slideToggle(250);
    });

    // ── Validation formulaire newsletter ─────────────────────────────────────
    // Vérifie les champs obligatoires avant soumission côté client
    $('#newsletterForm').on('submit', function (e) {
        var valid = true;
        var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        // Reset : on cache toutes les erreurs et retire les bordures rouges
        $('.field-error').hide();
        $('.form-control').removeClass('is-invalid');

        // Vérification du prénom
        if (!$('#firstName').val().trim()) {
            $('#err-firstName').show();
            $('#firstName').addClass('is-invalid');
            valid = false;
        }

        // Vérification de l'email (présence + format)
        if (!$('#email').val().trim() || !regex.test($('#email').val().trim())) {
            $('#err-email').show();
            $('#email').addClass('is-invalid');
            valid = false;
        }

        // Vérification de la case consentement
        if (!$('#consent').is(':checked')) {
            $('#err-consent').show();
            valid = false;
        }

        // Si au moins un champ invalide → on bloque et on remonte vers l'erreur
        if (!valid) {
            e.preventDefault();

            // Trouve le premier champ invalide (input rouge)
            var $premier = $('.form-control.is-invalid').first();

            // Fallback : si pas de champ is-invalid (ex: consent seul), cible l'erreur visible
            if ($premier.length === 0) {
                $premier = $('.field-error:visible').first();
            }

            // Scroll fluide vers le premier champ en erreur (offset 120px pour la navbar)
            if ($premier.length) {
                $('html, body').animate({
                    scrollTop: $premier.offset().top - 120
                }, 400, function () {
                    // Focus sur le champ après le scroll (pas sur checkbox)
                    if ($premier.is('input[type!="checkbox"]')) {
                        $premier.focus();
                    }
                });
            }
        }
    });

});
</script>
{% endblock %}
