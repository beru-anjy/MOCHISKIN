{% extends 'base.html.twig' %}
{% block title %}Connexion — MOCHISKIN{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  .auth-wrapper {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1rem;
    position: relative;
    overflow: hidden;
  }
  .auth-wrapper::before {
    content: '';
    position: fixed;
    width: 500px; height: 500px;
    background: radial-gradient(circle, var(--pink-light) 0%, transparent 70%);
    top: -200px; right: -150px;
    opacity: 0.6;
    pointer-events: none;
  }
  .auth-wrapper::after {
    content: '';
    position: fixed;
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--peach-light) 0%, transparent 70%);
    bottom: -150px; left: -100px;
    opacity: 0.6;
    pointer-events: none;
  }
  .auth-card {
    background: white;
    border-radius: 28px;
    box-shadow: 0 20px 60px rgba(255, 182, 193, 0.25);
    width: 100%;
    max-width: 460px;
    padding: 3rem 3rem 2.5rem;
    position: relative;
    z-index: 2;
    animation: slideUp 0.5s ease both;
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .auth-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 5px;
    background: linear-gradient(90deg, var(--peach-main), var(--pink-main), var(--peach-dark));
    border-radius: 28px 28px 0 0;
  }
  .auth-logo { text-align: center; margin-bottom: 2rem; }
  .auth-logo .brand {
    font-family: 'Savate', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--peach-dark), var(--pink-main));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 3px;
    display: block;
    margin-bottom: 4px;
  }
  .auth-logo .tagline { font-size: 0.85rem; color: #bbb; letter-spacing: 1px; }
  .auth-title {
    font-family: 'Savate', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #444;
    margin-bottom: 0.3rem;
    text-align: center;
  }
  .auth-subtitle { text-align: center; color: #aaa; font-size: 0.9rem; margin-bottom: 2rem; }
  .field-group { margin-bottom: 1.4rem; }
  .field-group label {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 8px;
  }
  .field-wrapper { position: relative; }
  .field-wrapper .field-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1rem;
    color: #ccc;
    pointer-events: none;
    transition: color 0.3s;
  }
  .field-wrapper input {
    width: 100%;
    padding: 0.85rem 1rem 0.85rem 2.8rem;
    border: 2px solid #f0e8e8;
    border-radius: 14px;
    font-family: 'Abel', sans-serif;
    font-size: 0.95rem;
    color: #555;
    background: #fdfafa;
    transition: all 0.25s ease;
    outline: none;
  }
  .field-wrapper input:focus {
    border-color: var(--peach-main);
    background: white;
    box-shadow: 0 0 0 4px rgba(255, 176, 132, 0.12);
  }
  .field-wrapper:focus-within .field-icon { color: var(--peach-dark); }
  .toggle-pw {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    font-size: 1rem;
    color: #ccc;
    background: none;
    border: none;
    padding: 0;
    transition: color 0.2s;
  }
  .toggle-pw:hover { color: var(--peach-dark); }
  .form-options {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.8rem;
    font-size: 0.88rem;
  }
  .remember-label { display: flex; align-items: center; gap: 8px; cursor: pointer; color: #888; }
  .remember-label input[type="checkbox"] {
    width: 16px; height: 16px;
    accent-color: var(--peach-dark);
    cursor: pointer;
  }
  .forgot-link {
    color: var(--peach-dark);
    text-decoration: none;
    font-size: 0.85rem;
    transition: opacity 0.2s;
  }
  .forgot-link:hover { opacity: 0.7; }
  .btn-auth {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, var(--peach-main) 0%, var(--pink-main) 100%);
    border: none;
    border-radius: 50px;
    color: white;
    font-family: 'Savate', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 6px 20px rgba(255, 182, 193, 0.4);
  }
  .btn-auth:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(255, 182, 193, 0.55); }
  .btn-auth:active { transform: translateY(0); }
  .alert-auth {
    background: #fff1f3;
    border: 1.5px solid #ffc2d1;
    border-radius: 12px;
    padding: 0.9rem 1.1rem;
    font-size: 0.88rem;
    color: #c0394b;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 8px;
    animation: shake 0.4s ease;
  }
  .alert-info-login {
    background: #dbeafe;
    border: 1.5px solid #93c5fd;
    border-radius: 12px;
    padding: 0.9rem 1.1rem;
    font-size: 0.88rem;
    color: #1e40af;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }
  .petal {
    position: absolute;
    font-size: 1.4rem;
    opacity: 0.18;
    pointer-events: none;
    animation: float 6s ease-in-out infinite;
  }
  .petal:nth-child(1) { top: 12px; right: 24px; animation-delay: 0s; }
  .petal:nth-child(2) { bottom: 40px; left: 20px; animation-delay: 2s; font-size: 1rem; }
  .petal:nth-child(3) { top: 50%; right: 16px; animation-delay: 4s; font-size: 0.9rem; }
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(15deg); }
  }
  .auth-footer { text-align: center; font-size: 0.9rem; color: #aaa; margin-top: 1.5rem; }
  .auth-footer a { color: var(--peach-dark); font-weight: 700; text-decoration: none; transition: opacity 0.2s; }
  .auth-footer a:hover { opacity: 0.7; }

  /* ── POP-UP COMPTE ACTIVE ── */
  .popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .popup-box {
    background: white;
    border-radius: 24px;
    padding: 2.5rem 2rem;
    max-width: 420px;
    width: 90%;
    text-align: center;
    box-shadow: 0 20px 60px rgba(255, 182, 193, 0.4);
    animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
    position: relative;
  }
  @keyframes popIn {
    from { opacity: 0; transform: scale(0.85) translateY(20px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .popup-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 5px;
    background: linear-gradient(90deg, var(--peach-main), var(--pink-main), var(--peach-dark));
    border-radius: 24px 24px 0 0;
  }
  .popup-icon {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    display: block;
    animation: bounce 0.6s ease 0.3s both;
  }
  @keyframes bounce {
    0%   { transform: scale(0); }
    60%  { transform: scale(1.2); }
    100% { transform: scale(1); }
  }
  .popup-title {
    font-family: 'Savate', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #444;
    margin-bottom: 0.8rem;
  }
  .popup-text { color: #888; font-size: 0.97rem; line-height: 1.7; margin-bottom: 1.8rem; }
  .popup-text strong { color: var(--peach-dark); }
  .popup-btn {
    background: linear-gradient(135deg, var(--peach-main), var(--pink-main));
    color: white;
    border: none;
    border-radius: 50px;
    padding: 0.8rem 2.5rem;
    font-family: 'Savate', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 5px 15px rgba(255, 182, 193, 0.4);
  }
  .popup-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(255, 182, 193, 0.55); }
</style>
{% endblock %}

{% block body %}

{# ══ POP-UP COMPTE ACTIVÉ ════════════════════════════════════════════════════ #}
{% set prenom = app.flashes('account_verified') %}
{% if prenom|length > 0 %}
  <div class="popup-overlay" id="verifiedPopup">
    <div class="popup-box">
      <span class="popup-icon">✅</span>
      <h2 class="popup-title">Compte activé !</h2>
      <p class="popup-text">
        Bienvenue <strong>{{ prenom|first }}</strong> ! 🌸<br>
        Votre compte a bien été activé.<br>
        Vous pouvez maintenant vous connecter.
      </p>
      <button class="popup-btn"
              onclick="document.getElementById('verifiedPopup').remove()">
        Se connecter →
      </button>
    </div>
  </div>
{% endif %}

<div class="auth-wrapper">
  <div class="auth-card">

    <span class="petal">🌸</span>
    <span class="petal">✿</span>
    <span class="petal">🌿</span>

    <div class="auth-logo">
      <span class="brand">MOCHISKIN</span>
      <span class="tagline">Prendre soin de sa peau naturellement</span>
    </div>

    <h1 class="auth-title">Bon retour 👋</h1>
    <p class="auth-subtitle">Espace réservé aux abonnées du blog</p>

    {% for message in app.flashes('info') %}
      <div class="alert-info-login">
        {{ message }}
      </div>
    {% endfor %}

    {% if error %}
      <div class="alert-auth">
        ⚠️ {{ error.messageKey|trans(error.messageData, 'security') }}
      </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}">

      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

      <div class="field-group">
        <label for="inputEmail">Email</label>
        <div class="field-wrapper">
          <input type="email"
                 id="inputEmail"
                 name="_username"
                 value="{{ last_username }}"
                 autocomplete="email"
                 placeholder="marie@exemple.com"
                 required
                 autofocus>
          <span class="field-icon">✉</span>
        </div>
      </div>

      <div class="field-group">
        <label for="inputPassword">Mot de passe</label>
        <div class="field-wrapper">
          <input type="password"
                 id="inputPassword"
                 name="_password"
                 autocomplete="current-password"
                 placeholder="••••••••"
                 required>
          <span class="field-icon">🔒</span>
          <button type="button" class="toggle-pw"
                  onclick="togglePassword()"
                  title="Afficher/masquer le mot de passe">👁</button>
        </div>
      </div>

      <div class="form-options">
        <label class="remember-label">
          <input type="checkbox" name="_remember_me">
          Se souvenir de moi
        </label>
        <a href="{{ path('app_forgot_password_request') }}" class="forgot-link">
          Mot de passe oublié ?
        </a>
      </div>

      <button type="submit" class="btn-auth">Se connecter →</button>

    </form>

    <div class="auth-footer" style="margin-top: 1.5rem;">
      Pas encore de compte ?
      <a href="{{ path('app_register') }}">Créer un compte</a>
    </div>

    <div class="auth-footer" style="margin-top: 0.8rem;">
      <a href="{{ path('app_home') }}" style="color:#bbb; font-weight:400;">
        ← Retour au blog
      </a>
    </div>

  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function togglePassword() {
  var input = document.getElementById('inputPassword');
  var btn   = document.querySelector('.toggle-pw');
  if (input.type === 'password') {
    input.type = 'text';
    btn.textContent = '🙈';
  } else {
    input.type = 'password';
    btn.textContent = '👁';
  }
}
</script>
{% endblock %}
