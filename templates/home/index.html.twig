{% extends 'base.html.twig' %}

{% block title %}MOCHISKIN{% endblock %}
{% block description %}MOCHISKIN — blog skincare naturel, routines beauté et conseils produits.{% endblock %}
{% block keywords %}skincare, routine, beauté, peau, soins naturels{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ── HERO ── */
    .hero-section {
        min-height: 80vh;
        display: flex; align-items: center; justify-content: center;
        text-align: center; padding: 4rem 2rem;
        position: relative; overflow: hidden;
    }
    .hero-section::before {
        content: ''; position: absolute;
        width: 400px; height: 400px;
        background: radial-gradient(circle, var(--pink-light) 0%, transparent 70%);
        top: -200px; right: -200px; opacity: 0.5;
    }
    .hero-section::after {
        content: ''; position: absolute;
        width: 300px; height: 300px;
        background: radial-gradient(circle, var(--peach-light) 0%, transparent 70%);
        bottom: -150px; left: -150px; opacity: 0.5;
    }
    .hero-content { position: relative; z-index: 2; }
    .hero-title    { font-size: 3.8rem; font-weight: 700; animation: fadeInUp 1s ease; color: var(--gray-soft); }
    .hero-subtitle { font-size: 1.4rem; font-weight: 300; animation: fadeInUp 1.2s ease; margin-bottom: 2rem; color: var(--gray-soft); }

    /* ── ROUTINE CARDS ── */
    .routine-card {
        background: white; border-radius: 20px; padding: 2.5rem;
        text-align: center; box-shadow: 0 10px 30px rgba(255,182,193,.15);
        transition: all .3s ease; margin-bottom: 2rem;
    }
    .routine-card:hover { transform: translateY(-10px); box-shadow: 0 15px 40px rgba(255,182,193,.25); }
    .routine-icon  { font-size: 3rem; margin-bottom: 1rem; }
    .routine-steps { font-size: 2rem; font-weight: 700; color: var(--peach-dark); margin-bottom: .5rem; }
    .routine-link  { display: inline-block; margin-top: 1.5rem; color: var(--peach-dark); text-decoration: none; font-weight: 600; transition: all .3s ease; }
    .routine-link:hover { color: var(--pink-main); transform: translateX(5px); }

    /* ── ARTICLES ── */
    .articles-section { padding: 5rem 0; background: white; }
    .article-card {
        background: white; border-radius: 15px; overflow: hidden;
        height: 100%; box-shadow: 0 5px 20px rgba(255,182,193,.1);
        transition: all .3s ease;
    }
    .article-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(255,182,193,.2); }
    .article-image             { width: 100%; height: 200px; object-fit: cover; display: block; }
    .article-image-placeholder { width: 100%; height: 200px; background: var(--peach-light); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
    .article-content   { padding: 1.5rem; }
    .article-title     { font-size: 1.2rem; margin-bottom: .5rem; color: var(--gray-soft); }
    .article-meta      { font-size: .85rem; color: #999; margin-bottom: 1rem; }
    .article-excerpt   { font-size: .95rem; line-height: 1.6; color: var(--gray-soft); margin-bottom: 1rem; }

    /* ── SEARCH ── */
    #searchInput {
        max-width: 320px;
        border: 2px solid var(--peach-light);
        border-radius: 25px;
        padding: .5rem 1rem;
    }
    #searchInput:focus { border-color: var(--peach-dark); outline: none; box-shadow: none; }

    /* ── ANIMATIONS ── */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 768px) {
        .hero-title    { font-size: 2.2rem; }
        .hero-subtitle { font-size: 1.1rem; }
    }
</style>
{% endblock %}

{% block body %}

    {# ══ HERO ══ #}
    <section class="hero-section">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">Prendre soin de sa peau<br>naturellement</h1>
                <p class="hero-subtitle">Découvrez les secrets d'une peau saine et éclatante 🌸</p>
                <a href="{{ path('app_about') }}" class="btn-primary-custom">Découvrir notre histoire</a>
            </div>
        </div>
    </section>

    {# ══ ROUTINE CARDS ══ #}
    <section class="py-5">
        <div class="container text-center">
            <h2 class="section-title">Ma routine skincare</h2>
            <p class="text-muted mb-5">Des routines simples et efficaces</p>
            <div class="row g-4 mt-2">
                <div class="col-md-6">
                    <div class="routine-card">
                        <div class="routine-icon">🌅</div>
                        <h3>Routine Matin</h3>
                        <p class="routine-steps">5 étapes</p>
                        <p class="text-muted">Durée : 10 minutes</p>
                        <a href="{{ path('app_routine') }}" class="routine-link">Voir ma routine complète →</a>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="routine-card">
                        <div class="routine-icon">🌙</div>
                        <h3>Routine Soir</h3>
                        <p class="routine-steps">7 étapes</p>
                        <p class="text-muted">Durée : 15 minutes</p>
                        <a href="{{ path('app_routine') }}" class="routine-link">Voir ma routine complète →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ══ ARTICLES RÉCENTS ══ #}
    <section class="articles-section">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="section-title">Articles récents</h2>
                <p class="text-muted mb-4">Nos derniers conseils skincare</p>
                <input type="text" id="searchInput"
                       class="form-control mx-auto"
                       placeholder="Rechercher un article...">
            </div>

            <div class="row g-4" id="articlesContainer">

                {% for article in articles %}
                    <div class="col-md-4 article-card-wrapper">
                        <div class="article-card">

                            <div class="article-content">
                                <h5 class="article-title">{{ article.title }}</h5>
                                <p class="article-meta">
                                    📅 {{ article.publishedAt|date('d/m/Y') }}
                                    &nbsp;·&nbsp;
                                    👁 {{ article.viewCount }} vues
                                </p>
                                <p class="article-excerpt">{{ article.excerpt|slice(0, 120) }}...</p>
                                <a href="{{ path('app_article_show', {slug: article.slug}) }}"
                                   class="btn-primary-custom btn-sm">
                                    Lire la suite
                                </a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    {# ── Fallback statique si la base de données est vide ── #}
                    <div class="col-md-4 article-card-wrapper">
                        <div class="article-card">
                            <div class="article-image-placeholder">☀️</div>
                            <div class="article-content">
                                <h5 class="article-title">Les 5 étapes d'une routine matin</h5>
                                <p class="article-meta">Ji-min Park — 15 jan. 2025</p>
                                <p class="article-excerpt">Découvrez comment préparer votre peau chaque matin pour une journée éclatante...</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 article-card-wrapper">
                        <div class="article-card">
                            <div class="article-image-placeholder">✨</div>
                            <div class="article-content">
                                <h5 class="article-title">Comment choisir son sérum</h5>
                                <p class="article-meta">Ji-min Park — 12 jan. 2025</p>
                                <p class="article-excerpt">Le sérum est l'étape clé de votre routine. Voici comment le choisir selon votre type de peau...</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 article-card-wrapper">
                        <div class="article-card">
                            <div class="article-image-placeholder">🌿</div>
                            <div class="article-content">
                                <h5 class="article-title">Les bienfaits du double nettoyage</h5>
                                <p class="article-meta">Seok-jin Han — 8 jan. 2025</p>
                                <p class="article-excerpt">Le double nettoyage est une technique coréenne incontournable pour une peau nette...</p>
                            </div>
                        </div>
                    </div>
                {% endfor %}

            </div>

            {% if articles|length > 0 %}
                <div class="text-center mt-5">
                    <a href="{{ path('app_articles') }}" class="btn-primary-custom">
                        Voir tous les articles
                    </a>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function () {
    // ── Recherche live ──
    $('#searchInput').on('keyup', function () {
        var s = $(this).val().toLowerCase();
        $('.article-card-wrapper').each(function () {
            var title   = $(this).find('.article-title').text().toLowerCase();
            var excerpt = $(this).find('.article-excerpt').text().toLowerCase();
            $(this).toggle(title.includes(s) || excerpt.includes(s));
        });
    });

    // ── Animations scroll ──
    function animateOnScroll() {
        $('[data-aos]').each(function () {
            if ($(this)[0].getBoundingClientRect().top < window.innerHeight - 100) {
                $(this).css({ opacity: 1, transform: 'translateY(0)' });
            }
        });
    }
    $('[data-aos]').css({ opacity: 0, transform: 'translateY(30px)', transition: 'all .6s ease' });
    $(window).on('scroll', animateOnScroll);
    animateOnScroll();
});
</script>
{% endblock %}
