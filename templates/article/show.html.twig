{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}
{% block description %}{{ article.excerpt }}{% endblock %}
{% block keywords %}{{ article.tags|map(t => t.name)|join(', ') }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ── ARTICLE HEADER ── */
    .article-header {
        background: white; padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 18px rgba(255,182,193,.1);
        margin-bottom: 1.5rem;
    }
    .article-title { font-size: 2.2rem; margin-bottom: 1rem; color: var(--gray-soft); }

    .meta-item {
        display: inline-flex; align-items: center;
        gap: .4rem; margin-right: 1.5rem;
        font-size: .9rem; color: #999;
    }

    .tag-badge {
        background: linear-gradient(135deg, var(--peach-main), var(--pink-main));
        color: white; border-radius: 20px;
        padding: .25rem .9rem; font-size: .8rem; margin: .2rem;
        display: inline-block;
    }

    /* ── CORPS ARTICLE ── */
    .article-body {
        background: white; padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 18px rgba(255,182,193,.1);
        line-height: 1.9; margin-bottom: 1.5rem;
        font-size: 1.05rem;
    }
    .article-body h2 { color: var(--peach-dark); margin: 2rem 0 1rem; }
    .article-body h3 { color: var(--gray-soft); margin: 1.5rem 0 .8rem; }
    .article-body p  { margin-bottom: 1.2rem; }
    .article-body img { max-width: 100%; border-radius: 12px; margin: 1rem 0; }

    /* ── IMAGE HERO ── */
    .article-hero-img {
        width: 100%; max-height: 400px;
        object-fit: cover; border-radius: 16px;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 18px rgba(255,182,193,.15);
    }

    /* ── COMMENTAIRES ── */
    .comments-section {
        background: white; padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 18px rgba(255,182,193,.1);
        margin-bottom: 2rem;
    }

    .comment-item {
        border-left: 3px solid var(--peach-main);
        background: var(--rose-light);
        border-radius: 0 12px 12px 0;
        padding: 1.2rem; margin-bottom: 1.2rem;
        transition: transform .2s ease;
    }
    .comment-item:hover { transform: translateX(4px); }

    /* ── FORMULAIRE COMMENTAIRE ── */
    .comment-form {
        background: var(--rose-light);
        border-radius: 14px; padding: 1.8rem; margin-top: 2rem;
    }
    .comment-form .form-control {
        border: 2px solid var(--peach-light);
        border-radius: 10px;
    }
    .comment-form .form-control:focus {
        border-color: var(--peach-dark);
        box-shadow: none;
    }
    .btn-comment {
        background: linear-gradient(135deg, var(--peach-main), var(--pink-main));
        color: white; border: none; border-radius: 25px;
        padding: .6rem 2rem; font-weight: 600;
        transition: all .3s ease;
    }
    .btn-comment:hover { transform: translateY(-2px); color: white; box-shadow: 0 5px 15px rgba(255,182,193,.4); }

    /* ── RETOUR ── */
    .btn-back {
        color: var(--peach-dark);
        border: 2px solid var(--peach-main);
        border-radius: 25px; padding: .6rem 2rem;
        font-weight: 600; text-decoration: none;
        transition: all .3s ease;
        display: inline-block;
    }
    .btn-back:hover { background: var(--peach-light); color: var(--peach-dark); }

    /* ── BADGE USER CONNECTÉ ── */
    .connected-badge {
        background: var(--peach-light);
        border-radius: 10px;
        padding: .8rem 1rem;
        margin-bottom: 1.2rem;
        font-size: .92rem;
        color: var(--gray-soft);
    }

    /* ── HINT NEWSLETTER ── */
    .newsletter-hint {
        font-size: .82rem;
        color: #aaa;
        margin-bottom: 1rem;
        font-style: italic;
    }
</style>
{% endblock %}

{% block body %}
<div class="container my-5">

    {# ══ IMAGE HERO ══ #}
    {% if article.imageUrl %}
        <img class="article-hero-img"
             src="{{ asset('uploads/articles/' ~ article.imageUrl) }}"
             alt="{{ article.title }}">
    {% endif %}

    {# ══ ENTÊTE ARTICLE ══ #}
    <div class="article-header">
        <h1 class="article-title">{{ article.title }}</h1>
        <div class="mb-2">
            <span class="meta-item">👤 {{ article.author.firstName }} {{ article.author.lastName }}</span>
            <span class="meta-item">📅 {{ article.publishedAt|date('d M Y') }}</span>
            <span class="meta-item">⏱ {{ article.readingTime }} min</span>
            <span class="meta-item">💬 {{ article.comments|length }} commentaires</span>
        </div>
        {% if article.tags|length > 0 %}
            <div class="mt-2">
                {% for tag in article.tags %}
                    <span class="tag-badge">{{ tag.name }}</span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# ══ CORPS DE L'ARTICLE ══ #}
    <div class="article-body">
        {{ article.content|raw }}
    </div>

    {# ══ MESSAGES FLASH ══ #}
    {# Affiche les messages de succès/erreur après soumission d'un commentaire #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert"
                 style="border-radius:12px; margin-bottom:1rem;">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# ══ COMMENTAIRES ══ #}
    <div class="comments-section" id="comments">
        <h3 class="mb-4">💬 Commentaires ({{ article.comments|length }})</h3>

        {% for comment in article.comments %}
            {% if comment.isApproved %}
                <div class="comment-item">
                    <div class="d-flex justify-content-between mb-1">
                        <strong style="color:var(--peach-dark);">
                            {# ✅ CORRIGÉ : getDisplayName() gère les 3 cas automatiquement #}
                            {# Cas 1 : User connecté  → prénom + nom du compte #}
                            {# Cas 2 : Abonné newsletter → prénom newsletter reconnu #}
                            {# Cas 3 : Visiteur anonyme → nom saisi dans le formulaire #}
                            {{ comment.displayName }}
                        </strong>
                        <small class="text-muted">{{ comment.createdAt|date('d M Y') }}</small>
                    </div>
                    <p class="mb-0">{{ comment.content }}</p>
                </div>
            {% endif %}
        {% else %}
            {# Fallback statique si DB vide #}
            <div class="comment-item">
                <div class="d-flex justify-content-between mb-1">
                    <strong style="color:var(--peach-dark);">Sophie Martin</strong>
                    <small class="text-muted">14 janvier 2025</small>
                </div>
                <p class="mb-0">Le sérum vitamine C fait vraiment la différence !</p>
            </div>
            <div class="comment-item">
                <div class="d-flex justify-content-between mb-1">
                    <strong style="color:var(--peach-dark);">Emma Dubois</strong>
                    <small class="text-muted">13 janvier 2025</small>
                </div>
                <p class="mb-0">Super article ! Pourrais-tu recommander une crème solaire sans traces blanches ?</p>
            </div>
            <div class="comment-item">
                <div class="d-flex justify-content-between mb-1">
                    <strong style="color:var(--peach-dark);">Julie Bernard</strong>
                    <small class="text-muted">12 janvier 2025</small>
                </div>
                <p class="mb-0">Excellent résumé ! J'ajouterais d'attendre quelques minutes entre chaque étape.</p>
            </div>
        {% endfor %}

        {# ══ FORMULAIRE COMMENTAIRE ══ #}
        <div class="comment-form">
            <h5 class="mb-3">✍️ Laisser un commentaire</h5>

            {# ── CAS 1 : User connecté ───────────────────────────────────────── #}
            {# app.user = objet User si connecté, null si visiteur #}
            {% if app.user %}

                {# On affiche son identité : pas besoin de saisir nom/email #}
                <div class="connected-badge">
                    ✅ Connecté en tant que
                    <strong>{{ app.user.firstName }} {{ app.user.lastName }}</strong>
                </div>

                {# Formulaire simplifié : seulement le contenu du commentaire #}
                {# action → route app_comment_add dans CommentController #}
                {# method POST → traitement côté serveur (pas de JS) #}
                <form method="post"
                      action="{{ path('app_comment_add', {slug: article.slug}) }}">

                    {# Token CSRF : protection anti-falsification #}
                    {# Vérifié dans CommentController::isCsrfTokenValid('comment', ...) #}
                    <input type="hidden" name="_token"
                           value="{{ csrf_token('comment') }}">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Commentaire *</label>
                        <textarea class="form-control" name="content"
                                  rows="4" required
                                  placeholder="Partagez votre avis..."></textarea>
                    </div>

                    <button type="submit" class="btn-comment">
                        Publier le commentaire
                    </button>
                </form>

            {# ── CAS 2 & 3 : Visiteur (anonyme ou abonné newsletter) ──────────── #}
            {% else %}

                {# Hint discret pour les abonnés newsletter (Option B) #}
                {# Si l'email saisi est dans Newsletter → prénom auto utilisé #}
                <p class="newsletter-hint">
                    💌 Abonné(e) à la newsletter ?
                    Utilisez votre email d'inscription pour que votre prénom
                    apparaisse automatiquement.
                </p>

                {# Formulaire complet avec nom + email + commentaire #}
                <form method="post"
                      action="{{ path('app_comment_add', {slug: article.slug}) }}">

                    {# Token CSRF : protection anti-falsification #}
                    <input type="hidden" name="_token"
                           value="{{ csrf_token('comment') }}">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nom *</label>
                        {# name="authorName" → récupéré dans CommentController #}
                        <input type="text" class="form-control"
                               name="authorName" required
                               placeholder="Votre prénom">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Email * <small class="text-muted">(non publié)</small>
                        </label>
                        {# name="authorEmail" → utilisé par l'Option B pour vérifier #}
                        {# si cet email est dans la table Newsletter #}
                        <input type="email" class="form-control"
                               name="authorEmail" required
                               placeholder="votre@email.com">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Commentaire *</label>
                        {# name="content" → récupéré dans CommentController #}
                        <textarea class="form-control" name="content"
                                  rows="4" required
                                  placeholder="Partagez votre avis..."></textarea>
                    </div>

                    <button type="submit" class="btn-comment">
                        Publier le commentaire
                    </button>
                </form>

            {% endif %}
        </div>
    </div>

    <div class="text-center mb-5">
        <a href="{{ path('app_articles') }}" class="btn-back">← Retour aux articles</a>
    </div>

</div>
{% endblock %}

{# ══ JAVASCRIPT ══ #}
{# NOTE : Le formulaire est maintenant traité côté SERVEUR par CommentController #}
{# Le JS jQuery de l'ancienne version est supprimé car il simulait uniquement #}
{# l'ajout du commentaire sans vraiment le sauvegarder en base de données #}
{# La soumission du formulaire recharge la page avec un message flash #}
{% block javascripts %}
{{ parent() }}
{% endblock %}
