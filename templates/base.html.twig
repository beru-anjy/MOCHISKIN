<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{% endblock %} — MOCHISKIN</title>

    <meta name="description" content="{% block description %}Blog skincare naturel{% endblock %}">
    <meta name="keywords"    content="{% block keywords %}skincare, beaute, routine{% endblock %}">
    <meta name="robots"      content="index, follow">
    <meta name="author"      content="Anjy">

    {# ── Google Fonts ── #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Abel&family=Savate:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">

    {# ── Bootstrap CSS ── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    {# ── Font Awesome ── #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    {# ── Ton CSS global (APRÈS Bootstrap pour pouvoir l'écraser) ── #}
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">

    {# ── CSS spécifique à chaque page ── #}

    {% block stylesheets %}
    <style>
        /* ========== VARIABLES COULEURS ========== */
        :root {
            --peach-light: #FFE5D9;
            --peach-main: #FFCDB2;
            --peach-dark: #FFB4A2;
            --pink-light: #FFD7E4;
            --pink-main: #FFC2D1;
            --rose-light: #FFF0F5;
            --gray-soft: #6B6B6B;
            --white: #FFFFFF;
        }
        
        /* ========== STYLES GENERAUX ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: "Abel", sans-serif;
            font-weight: 400;
            color: var(--gray-soft);
            background: linear-gradient(135deg, var(--rose-light) 0%, var(--peach-light) 100%);
            min-height: 100vh;
        }
        
        h1, h2, h3, h4, h5, h6 {
            font-family: "Savate", sans-serif;
            color: var(--gray-soft);
        }
        
        /* ========== NAVIGATION ========== */
        .navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 20px rgba(255, 182, 193, 0.1);
            padding: 1rem 0;
        }
        
        .navbar-brand {
            font-family: "Savate", sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--peach-dark);
            letter-spacing: 2px;
        }
        
        .nav-link {
            color: var(--gray-soft);
            font-weight: 500;
            margin: 0 1rem;
            transition: color 0.3s ease;
            position: relative;
        }
        
        .nav-link:hover {
            color: var(--peach-dark);
        }
        
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--peach-dark);
            transition: width 0.3s ease;
        }
        
        .nav-link:hover::after {
            width: 100%;
        }
        
        /* ========== BOUTONS ========== */
        .btn-primary-custom {
            background: linear-gradient(135deg, var(--peach-main) 0%, var(--pink-main) 100%);
            border: none;
            padding: 0.8rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            color: white;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(255, 182, 193, 0.3);
        }
        
        .btn-primary-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(255, 182, 193, 0.5);
            color: white;
        }
        
        /* ========== CARDS ========== */
        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(255, 182, 193, 0.15);
            transition: transform 0.3s ease;
            background: white;
        }
        
        .card:hover {
            transform: translateY(-5px);
        }
        
        .card-img-top {
            border-radius: 20px 20px 0 0;
            height: 200px;
            object-fit: cover;
        }
        
        /* ========== FOOTER ========== */
        footer {
            background: linear-gradient(135deg, var(--peach-main) 0%, var(--pink-main) 100%);
            color: white;
            padding: 3rem 0 1rem;
            margin-top: 5rem;
        }
        
        footer h5 {
            color: white;
            margin-bottom: 1rem;
            font-family: "Abel", sans-serif;
            font-weight: 400;
        }
        
        footer a {
            color: white;
            text-decoration: none;
            display: block;
            margin-bottom: 0.5rem;
            transition: opacity 0.3s ease;
        }
        
        footer a:hover {
            opacity: 0.8;
            padding-left: 5px;
        }
        
        .copyright {
            text-align: center;
            padding-top: 2rem;
            margin-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.3);
        }
        
        /* ========== MESSAGES FLASH ========== */
        .alert {
            border-radius: 15px;
            padding: 1rem 1.5rem;
            margin-bottom: 1rem;
        }
    </style>
    {% endblock %}
</head>
<body>

{# ══════════ NAVBAR ══════════ #}
<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">

        <a class="navbar-brand" href="{{ path('app_home') }}">MOCHISKIN</a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav"
                aria-controls="navbarNav"
                aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_articles') }}">Articles</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_routine') }}">Routine</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_about') }}">À propos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_newsletter') }}">Newsletter</a>
                </li>
                 <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_contact') }}">Contact</a>
                </li>
            </ul>
        </div>

    </div>
</nav>

{# ══════════ MESSAGES FLASH ══════════ #}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show container mt-3" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

{# ══════════ CONTENU PRINCIPAL ══════════ #}
{% block body %}{% endblock %}

{# ══════════ FOOTER ══════════ #}
<footer>
    <div class="container">
        <div class="row">

            <div class="col-md-4 mb-4">
                <h5>MOCHISKIN</h5>
                <p style="font-size: .9rem; line-height: 1.6; color: rgba(255,255,255,.85);">
                    Blog dédié au skincare naturel et aux routines beauté.
                </p>
                <div class="mt-3 d-flex gap-2">
                    <a href="#" title="Instagram" class="footer-social">
                        <i class="fa-brands fa-instagram"></i>
                    </a>
                    <a href="#" title="Pinterest" class="footer-social">
                        <i class="fa-brands fa-pinterest"></i>
                    </a>
                    <a href="#" title="YouTube" class="footer-social">
                        <i class="fa-brands fa-youtube"></i>
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <h5>Navigation</h5>
                <a href="{{ path('app_home') }}">Accueil</a>
                <a href="{{ path('app_articles') }}">Articles</a>
                <a href="{{ path('app_routine') }}">Ma Routine</a>
                <a href="{{ path('app_about') }}">À propos</a>
                <a href="{{ path('app_newsletter') }}">Newsletter</a>
                <a href="{{ path('app_contact') }}">Contact</a>
            </div>

            <div class="col-md-4 mb-4">
                <h5>Informations</h5>
                <a href="{{ path('app_mentions_legales') }}">Mentions légales</a>
                <a href="{{ path('app_politique_confidentialite') }}">Politique de confidentialité</a>
                <a href="{{ path('app_contact') }}">Nous contacter</a>
            </div>

        </div>

        <div class="copyright">
            &copy; {{ 'now'|date('Y') }} MOCHISKIN. Tous droits réservés.
        </div>
    </div>
</footer>

{# ══════════ SCRIPTS ══════════ #}
{# CRITIQUE : jQuery DOIT être chargé AVANT Bootstrap JS #}
{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}

</body>
</html>
