<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{% endblock %} — MOCHISKIN</title>

    <meta name="description" content="{% block description %}Blog skincare naturel{% endblock %}">
    <meta name="keywords"    content="{% block keywords %}skincare, beaute, routine{% endblock %}">
    <meta name="robots"      content="index, follow">
    <meta name="author"      content="Angelina PINTO - CEO">

    {# Favicon — logo affiché dans l'onglet du navigateur #}
    <link rel="icon" type="image/png" href="{{ asset('images/logo.png') }}">
    <link rel="apple-touch-icon" href="{{ asset('images/logo.png') }}">

    {# Google Fonts : Abel (corps) + Savate (titres) #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Abel&family=Savate:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">

    {# Bootstrap 5 #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    {# Font Awesome : icônes réseaux sociaux et UI #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    {# CSS global du projet — chargé après Bootstrap pour pouvoir l'écraser #}
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">

    {% block stylesheets %}
    <style>
        /* ── Palette de couleurs globale ── */
        :root {
            --peach-light: #FFE5D9;
            --peach-main:  #FFCDB2;
            --peach-dark:  #FFB4A2;
            --pink-light:  #FFD7E4;
            --pink-main:   #FFC2D1;
            --rose-light:  #FFF0F5;
            --gray-soft:   #6B6B6B;
            --white:       #FFFFFF;
        }

        /* ── Reset minimal + box-sizing global ── */
        * { margin: 0; padding: 0; box-sizing: border-box; }

        /* ── Corps de page : fond dégradé pêche/rose, hauteur pleine page ── */
        body {
            font-family: "Abel", sans-serif;
            font-weight: 400;
            color: var(--gray-soft);
            background: linear-gradient(135deg, var(--rose-light) 0%, var(--peach-light) 100%);
            min-height: 100vh;
        }

        /* ── Titres : police Savate ── */
        h1, h2, h3, h4, h5, h6 {
            font-family: "Savate", sans-serif;
            color: var(--gray-soft);
        }

        /* ── Navbar : fond blanc semi-transparent avec effet flou ── */
        .navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 20px rgba(255, 182, 193, 0.1);
            padding: 1rem 0;
        }

       /* ── Logo MOCHISKIN dans la navbar ── */
        .navbar-brand {
            font-family: "Savate", sans-serif;
            font-size: 3rem;   
            font-weight: 700;
            color: var(--peach-dark);
            letter-spacing: 2px;
        }

        /* ── Liens de navigation : couleur + soulignement animé au hover ── */
        .nav-link {
            color: var(--gray-soft);
            font-weight: 500;
            margin: 0 1rem;
            transition: color 0.3s ease;
            position: relative;
        }

        .nav-link:hover { color: var(--peach-dark); }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -5px; left: 0;
            width: 0; height: 2px;
            background: var(--peach-dark);
            transition: width 0.3s ease;
        }

        .nav-link:hover::after { width: 100%; }

        /* ── Bouton CTA principal : dégradé pêche/rose, coins arrondis ── */
        .btn-primary-custom {
            background: linear-gradient(135deg, var(--peach-main) 0%, var(--pink-main) 100%);
            border: none;
            padding: 0.8rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            color: white;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(255, 182, 193, 0.3);
        }

        .btn-primary-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(255, 182, 193, 0.5);
            color: white;
        }

        /* ── Cards articles : fond blanc, ombres douces, effet lift au hover ── */
        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(255, 182, 193, 0.15);
            transition: transform 0.3s ease;
            background: white;
        }

        .card:hover { transform: translateY(-5px); }

        .card-img-top {
            border-radius: 20px 20px 0 0;
            height: 200px;
            object-fit: cover;
        }

        /* ── Footer : dégradé pêche/rose, liens blancs ── */
        footer {
            background: linear-gradient(135deg, var(--peach-main) 0%, var(--pink-main) 100%);
            color: white;
            padding: 3rem 0 1rem;
            margin-top: 5rem;
        }

        footer h5 {
            color: white;
            margin-bottom: 1rem;
            font-family: "Abel", sans-serif;
            font-weight: 400;
        }

        footer a {
            color: white;
            text-decoration: none;
            display: block;
            margin-bottom: 0.5rem;
            transition: opacity 0.3s ease;
        }

        footer a:hover { opacity: 0.8; padding-left: 5px; }

        .copyright {
            text-align: center;
            padding-top: 2rem;
            margin-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.3);
        }

        /* ── Messages flash (succès, erreur, info) ── */
        .alert { border-radius: 15px; padding: 1rem 1.5rem; margin-bottom: 1rem; }

        /* ── Prénom affiché quand l'utilisateur est connecté ── */
        .navbar-user-name {
            color: var(--gray-soft);
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* ── Bouton Admin : réservé aux utilisateurs ROLE_ADMIN ── */
        .btn-navbar-admin {
            background: #7c3aed;
            color: white;
            border-radius: 20px;
            font-size: 0.8rem;
            padding: 0.3rem 0.9rem;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .btn-navbar-admin:hover { background: #6d28d9; color: white; }

        /* ── Bouton Déconnexion ── */
        .btn-navbar-logout {
            background: var(--peach-main);
            color: white;
            border-radius: 20px;
            font-size: 0.85rem;
            padding: 0.3rem 0.9rem;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .btn-navbar-logout:hover { background: var(--peach-dark); color: white; }

        /* ── Bouton Connexion : style discret pour visiteurs ── */
        .btn-navbar-login {
            background: transparent;
            color: var(--gray-soft);
            border: 1px solid var(--peach-light);
            border-radius: 20px;
            font-size: 0.85rem;
            padding: 0.3rem 0.9rem;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .btn-navbar-login:hover {
            background: var(--peach-light);
            color: var(--gray-soft);
        }

        /* ── Bouton Créer un compte : mis en avant avec dégradé pêche/rose ── */
        .btn-navbar-register {
            background: linear-gradient(135deg, var(--peach-main), var(--pink-main));
            color: white;
            border-radius: 20px;
            font-size: 0.85rem;
            padding: 0.3rem 0.9rem;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .btn-navbar-register:hover {
            background: linear-gradient(135deg, var(--peach-dark), var(--peach-main));
            color: white;
        }
    </style>
    {% endblock %}
</head>
<body>

{# ══════════ NAVBAR ══════════ #}
<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">

        {# Logo — redirige vers l'accueil #}
        {# <a class="navbar-brand" href="{{ path('app_home') }}">MOCHISKIN</a> #}
        {# Logo image — redirige vers l'accueil #}
        <a class="navbar-brand" href="{{ path('app_home') }}">
            <img src="{{ asset('images/logo.png') }}"
            alt="MOCHISKIN"
            height="120"
             style="object-fit: contain;">
        </a>

        {# Burger menu — visible uniquement sur mobile #}
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav"
                aria-controls="navbarNav"
                aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">

            {# Liens principaux centrés — ajouter ici toute nouvelle page publique #}
            <ul class="navbar-nav mx-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_articles') }}">Articles</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_routine') }}">Routine</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_about') }}">À propos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_newsletter') }}">Newsletter</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_contact') }}">Contact</a>
                </li>
            </ul>

            {# ── ZONE AUTH ── app.user = User connecté | null = visiteur #}
            <div class="d-flex align-items-center gap-2 ms-2">

                {% if app.user %}

                    {# Prénom de l'utilisateur connecté #}
                    <span class="navbar-user-name">
                        👋 {{ app.user.firstName }}
                    </span>

                    {# Bouton Admin — affiché uniquement pour ROLE_ADMIN #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="/admin" class="btn-navbar-admin">
                            ⚙️ Admin
                        </a>
                    {% endif %}

                    {# Déconnexion — route définie dans security.yaml #}
                    <a href="{{ path('app_logout') }}" class="btn-navbar-logout">
                        Déconnexion
                    </a>

                {% else %}

                    {# Visiteur non connecté : accès inscription et connexion #}

                    {# Créer un compte — route app_register dans RegistrationController #}
                    <a href="{{ path('app_register') }}" class="btn-navbar-register">
                        Créer un compte
                    </a>

                    {# Connexion — route app_login dans SecurityController #}
                    <a href="{{ path('app_login') }}" class="btn-navbar-login">
                        Connexion
                    </a>

                {% endif %}

            </div>
            {# ── FIN ZONE AUTH ── #}

        </div>
    </div>
</nav>

{# ══════════ MESSAGES FLASH ══════════ #}
{# Affiche les retours utilisateur après une action (ex : inscription réussie, erreur login) #}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show container mt-3" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

{# ══════════ CONTENU PRINCIPAL — surchargé par chaque page enfant ══════════ #}
{% block body %}{% endblock %}

{# ══════════ FOOTER ══════════ #}
<footer>
    <div class="container">
        <div class="row">

            {# Colonne 1 : présentation du blog + réseaux sociaux #}
            <div class="col-md-4 mb-4">
                <h5>MOCHISKIN</h5>
                <p style="font-size:.9rem; line-height:1.6; color:rgba(255,255,255,.85);">
                    Blog dédié au skincare naturel et aux routines beauté.
                </p>
                <div class="mt-3 d-flex gap-2">
                    <a href="#" title="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" title="Pinterest"><i class="fa-brands fa-pinterest"></i></a>
                    <a href="#" title="YouTube"><i class="fa-brands fa-youtube"></i></a>
                </div>
            </div>

            {# Colonne 2 : liens de navigation dupliqués pour accessibilité footer #}
            <div class="col-md-4 mb-4">
                <h5>Navigation</h5>
                <a href="{{ path('app_home') }}">Accueil</a>
                <a href="{{ path('app_articles') }}">Articles</a>
                <a href="{{ path('app_routine') }}">Ma Routine</a>
                <a href="{{ path('app_about') }}">À propos</a>
                <a href="{{ path('app_newsletter') }}">Newsletter</a>
                <a href="{{ path('app_contact') }}">Contact</a>
            </div>

            {# Colonne 3 : liens légaux et contact #}
            <div class="col-md-4 mb-4">
                <h5>Informations</h5>
                <a href="{{ path('app_mentions_legales') }}">Mentions légales</a>
                <a href="{{ path('app_politique_confidentialite') }}">Politique de confidentialité</a>
                <a href="{{ path('app_contact') }}">Nous contacter</a>
            </div>

        </div>

        {# Année générée dynamiquement — pas besoin de la mettre à jour manuellement #}
        <div class="copyright">
            &copy; {{ 'now'|date('Y') }} MOCHISKIN. Tous droits réservés.
        </div>
    </div>
</footer>

{# ══════════ SCRIPTS ══════════ #}
{# jQuery chargé AVANT Bootstrap — obligatoire pour les plugins jQuery #}
{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}

</body>
</html>