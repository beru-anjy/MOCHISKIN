{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — MOCHISKIN{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <h1>Mot de passe oublié 🔑</h1>

    {{ form_start(requestForm) }}
        {{ form_row(requestForm.email) }}
        <p>
            <small>Entrez votre adresse email et nous vous enverrons
            un lien pour réinitialiser votre mot de passe.</small>
        </p>
        <button class="btn btn-primary">Envoyer le lien</button>
    {{ form_end(requestForm) }}
{% endblock %}