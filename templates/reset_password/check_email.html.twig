{% extends 'base.html.twig' %}

{% block title %}Email envoyé — MOCHISKIN{% endblock %}

{% block body %}
    <p>
        Si un compte correspond à votre adresse email, vous allez recevoir
        un lien valable
        {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
