{% extends 'base.html.twig' %}

{% block title %}Contact{% endblock %}
{% block description %}Contactez l'équipe MOCHISKIN pour toute question ou collaboration.{% endblock %}
{% block keywords %}contact, skincare, collaboration, question{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ── HERO ── */
    .hero-contact {
        background: linear-gradient(135deg, var(--peach-main) 0%, var(--pink-main) 100%);
        color: white;
        padding: 5rem 0 3rem;
        text-align: center;
        margin-bottom: 3rem;
    }
    .hero-contact h1 { font-size: 3rem; color: white; }
    .hero-contact p  { opacity: 0.9; color: white; }

    /* ── INFO CARDS ── */
    .info-card {
        display: flex;
        align-items: flex-start;
        gap: 1.2rem;
        background: var(--rose-light);
        border-radius: 15px;
        padding: 1.2rem 1.5rem;
        margin-bottom: 1rem;
        transition: all 0.3s ease;
    }
    .info-card:hover { transform: translateX(8px); box-shadow: 0 5px 15px rgba(255,182,193,.2); }
    .info-icon { font-size: 1.8rem; flex-shrink: 0; }
    .info-card h6 { color: var(--peach-dark); font-weight: 600; margin-bottom: .2rem; }
    .info-card p, .info-card a { color: var(--gray-soft); font-size: .95rem; }

    /* ── FORMULAIRE ── */
    .contact-form-box {
        background: white;
        border-radius: 20px;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(255,182,193,.15);
    }
    .form-control, .form-select {
        border: 2px solid var(--peach-light);
        border-radius: 10px;
        padding: .75rem 1rem;
        transition: border-color .3s ease;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--peach-dark);
        box-shadow: none;
    }

    .field-error {
        color: #dc3545;
        font-size: 0.82rem;
        margin-top: 4px;
        display: none;
    }
    
    .form-control.is-invalid,
    .form-select.is-invalid {
        border-color: #dc3545;
    }   
    .consent-row {
        display: flex;
        align-items: flex-start;
        gap: .8rem;
        background: var(--rose-light);
        border-radius: 10px;
        padding: 1rem;
    }
    
    .btn-send {
        background: linear-gradient(135deg, var(--peach-main) 0%, var(--pink-main) 100%);
        border: none;
        padding: .9rem 3rem;
        border-radius: 50px;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        width: 100%;
        transition: all .3s ease;
        box-shadow: 0 5px 15px rgba(255,182,193,.3);
    }
    .btn-send:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(255,182,193,.5); }
</style>
{% endblock %}

{% block body %}

    <div class="hero-contact">
        <div class="container">
            <h1>Contactez-moi</h1>
            <p class="lead">Une question, une proposition de collaboration ? Écrivez-moi !</p>
        </div>
    </div>

    <div class="container my-5">
        <div class="row g-5">

            {# ── INFOS (col gauche) ── #}
            <div class="col-md-5">
                <h2 class="mb-4" style="color:var(--peach-dark);">Informations de contact</h2>

                <div class="info-card">
                    <span class="info-icon">📞</span>
                    <div>
                        <h6>Téléphone</h6>
                        <a href="tel:+33123456789">+33 1 23 45 67 89</a>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">📧</span>
                    <div>
                        <h6>Email</h6>
                        <a href="mailto:contact@mochiskin.fr">contact@mochiskin.fr</a>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">📍</span>
                    <div>
                        <h6>Adresse</h6>
                        <p class="mb-0">123 Rue de l'Exemple<br>75001 Paris, France</p>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">🕐</span>
                    <div>
                        <h6>Horaires de réponse</h6>
                        <p class="mb-0">Lun – Ven · 9h00 – 18h00</p>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">🌐</span>
                    <div>
                        <h6>Réseaux sociaux</h6>
                        <p class="mb-0">
                            <a href="https://fr.pinterest.com/pin/2111131072467715/" style="margin-right:.8rem;">Pinterest</a>
                            <a href="https://youtu.be/APC16_cpYyk?si=fiqHGz4n_9F309OE">YouTube</a>
                        </p>
                    </div>
                </div>
            </div>

            {# ── FORMULAIRE (col droite)
               action = route app_contact_send (POST)
               Le formulaire soumet vers Symfony qui sauvegarde en base
               puis redirige avec un flash message de confirmation ── #}
            <div class="col-md-7">
                <div class="contact-form-box">
                    <h3 class="mb-1" style="color:var(--peach-dark);">Envoyez-nous un message</h3>
                    <p class="text-muted mb-4 small">Nous vous répondrons dans les 24–48 heures.</p>

                    {# action → route POST qui traite et sauvegarde le message en base #}
                    <form id="contactForm"
                          method="POST"
                          action="{{ path('app_contact_send') }}">

                        {# Token CSRF — protège contre les soumissions frauduleuses #}
                        <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nom complet *</label>
                            <input type="text" class="form-control"
                                   id="fullName" name="fullName"
                                   required placeholder="Votre nom et prénom">
                                   <span class="field-error" id="err-fullName">Ce champ est obligatoire.</span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Adresse e-mail *</label>
                            <input type="email" class="form-control"
                                   id="email" name="email"
                                   required placeholder="votre.email@exemple.com">
                                   <span class="field-error" id="err-email">Email invalide ou obligatoire.</span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Sujet *</label>
                            <select class="form-select" id="subject" name="subject" required>
                                <option value="">Sélectionnez un sujet</option>
                                <option value="question">Question générale</option>
                                <option value="collaboration">Proposition de collaboration</option>
                                <option value="produit">Question sur un produit</option>
                                <option value="partenariat">Partenariat</option>
                                <option value="technique">Problème technique</option>
                                <option value="autre">Autre</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Votre message *</label>
                            <textarea class="form-control"
                                      id="message" name="message"
                                      rows="5" required
                                      placeholder="Écrivez votre message ici..."></textarea>
                                      <span class="field-error" id="err-message">Message obligatoire (min. 10 caractères).</span>
                        </div>

                        <div class="mb-4">
                            <div class="consent-row">
                                <input type="checkbox" id="consent" required
                                       style="width:18px;height:18px;margin-top:2px;">
                                <label for="consent">
                                    J'ai lu et j'accepte la politique de confidentialité *
                                </label>
                            </div>
                                <span class="field-error" id="err-consent">Vous devez accepter la politique de confidentialité.</span>
                        </div>

                        <button type="submit" class="btn-send">Envoyer le message</button>

                    </form>
                </div>
            </div>

        </div>
    </div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $('#contactForm').on('submit', function (e) {
    var valid = true;
    var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    // Reset
    $('.field-error').hide();
    $('.form-control, .form-select').removeClass('is-invalid');

    if (!$('#fullName').val().trim()) {
        $('#err-fullName').show();
        $('#fullName').addClass('is-invalid');
        valid = false;
    }
    if (!$('#email').val().trim() || !regex.test($('#email').val().trim())) {
        $('#err-email').show();
        $('#email').addClass('is-invalid');
        valid = false;
    }
    if (!$('#subject').val()) {
        $('#err-subject').show();
        $('#subject').addClass('is-invalid');
        valid = false;
    }
    if ($('#message').val().trim().length < 10) {
        $('#err-message').show();
        $('#message').addClass('is-invalid');
        valid = false;
    }
    if (!$('#consent').is(':checked')) {
        $('#err-consent').show();
        valid = false;
    }

    if (!valid) e.preventDefault();
});
</script>
{% endblock %}